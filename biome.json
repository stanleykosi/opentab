{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/.next",
      "!**/.deploy-smoke",
      "!**/.turbo",
      "!**/dist",
      "!**/coverage",
      "!**/lib",
      "!**/out",
      "!**/cache",
      "!**/broadcast",
      "!**/artifacts",
      "!**/test-results",
      "!**/playwright-report",
      "!**/next-env.d.ts",
      "!**/migrations/meta"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noExplicitAny": "error"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  }
}
