# OpenTab deployment variables
#
# This is a dashboard checklist, not a local-development file. Leave values
# blank here and enter real secrets only in Vercel, Railway, or Supabase.
# Vercel's "Automatically expose System Environment Variables" setting must
# stay enabled so APP_ENV, the public origin, and the Git release ID are derived.
# Safe application policy, chain IDs, USDC, timeouts, limits, ports, health
# settings, and all disabled feature defaults live in validated source code.

# VERCEL — required for the web/API service
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=
MAGIC_SECRET_KEY=
MAGIC_CLIENT_ID=
# Supabase opentab_runtime role through the transaction pooler (:6543), with TLS.
DATABASE_URL=
# One externally reachable authenticated rediss:// URL shared with Railway.
REDIS_URL=
# Generate one independent random value of at least 32 characters.
OPENTAB_SECRET_ROOT=

# RAILWAY — required for the canonical Arbitrum indexer/reconciler
# Copy the two RPC URLs, both contract addresses, and deployment block to
# Vercel as well before enabling its payment canary.
# Supabase opentab_indexer role through the session pooler/direct endpoint (:5432), with TLS.
DATABASE_URL_INDEXER=
ARBITRUM_RPC_URL=
ARBITRUM_FALLBACK_RPC_URL=
NEXT_PUBLIC_CHECKOUT_ADDRESS=
NEXT_PUBLIC_PASS_ADDRESS=
INDEXER_DEPLOYMENT_BLOCK=

# PARTICLE LIVE PROFILE — copy the same reviewed values to Vercel and Railway
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_UUID=
PARTICLE_EIP7702_IMPLEMENTATION_ADDRESS=
PARTICLE_EIP7702_IMPLEMENTATION_CODE_HASH=
PARTICLE_RESPONSE_PROFILE_ID=
PARTICLE_DEPLOYMENTS_FIXTURE_DIGEST=
PARTICLE_AUTH_FIXTURE_DIGEST=
PARTICLE_SUBMISSION_FIXTURE_DIGEST=
PARTICLE_STATUS_FIXTURE_DIGEST=
PARTICLE_MAGIC_AUTHORIZATION_NONCE_OFFSET=
PARTICLE_ALLOWED_SOURCE_TOKENS=
PARTICLE_SOURCE_CALL_PROFILES_JSON=

# VERCEL PAYMENT CANARY — required only when enabling real checkout
# Keep both flags false until the tiny-value canary is confirmed by the
# canonical Arbitrum OrderPaid event. No other product feature flag is needed
# for the initial deployment.
PARTICLE_LIVE_ENABLED=false
PAYMENTS_ENABLED=false
PLATFORM_FEE_BPS=
ORDER_SIGNER_KMS_KEY_ID=
ORDER_SIGNER_ADDRESS=
AWS_KMS_REGION=
VERCEL_AWS_ROLE_ARN=
