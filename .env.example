# OpenTab dashboard deployment checklist
#
# Enter secrets only in Vercel/Railway/Supabase dashboards. Values in the
# SHARED block must be entered in both Vercel and Railway. Contract addresses,
# Arbitrum One chain policy, deployment block, fallback RPC, confirmations,
# ports, limits, and safe feature defaults are pinned in validated source.

# SHARED — enter the same value in Vercel and Railway
APP_ENV=demo-mainnet
ARBITRUM_RPC_URL=
REDIS_URL=
PARTICLE_LIVE_ENABLED=true
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_UUID=

# VERCEL ONLY — web, API, Magic, and application release evidence
NEXT_PUBLIC_APP_ENV=demo-mainnet
NEXT_PUBLIC_APP_ORIGIN=https://opentab-opal.vercel.app
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=
MAGIC_SECRET_KEY=
# Supabase opentab_runtime role, transaction pooler port 6543, sslmode=require.
DATABASE_URL=
# Two different random secrets, each at least 32 characters.
OPENTAB_SECRET_ROOT=
# Server-only password for one-time Particle profile activation/rotation.
# Normal APIs stay online without it, but /operator/particle cannot certify.
PARTICLE_CERTIFICATION_TOKEN=
PROVIDER_MODE=live
PAYMENTS_ENABLED=true
PLATFORM_FEE_BPS=0
# Hackathon demo-mainnet uses the reviewed private-key signer path. The key
# must match ORDER_SIGNER_ADDRESS and must never be exposed with NEXT_PUBLIC_.
DEMO_PRIVATE_KEY_ORDER_SIGNER_ENABLED=true
ORDER_SIGNER_MODE=private-key
ORDER_SIGNER_PRIVATE_KEY=
ORDER_SIGNER_ADDRESS=0x03981bA2a287b173A16b2c0a04088aB33AA98526

# RAILWAY ONLY — canonical Arbitrum indexer/reconciler
# Supabase opentab_indexer role, session pooler/direct port 5432, sslmode=require.
DATABASE_URL_INDEXER=
# The Particle profile scope is derived from the shared Particle/contract
# configuration. No Git release variable is required on Railway.
