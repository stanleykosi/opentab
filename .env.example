# Environment
APP_ENV=local
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
LOG_LEVEL=info
PROVIDER_MODE=deterministic
DETERMINISTIC_DEMO_ENABLED=true

# Feature flags: keep live money paths disabled until explicit protected setup
PAYMENTS_ENABLED=false
PARTICLE_LIVE_ENABLED=false
BOOTSTRAP_SPONSOR_ENABLED=false
BOOTSTRAP_SPONSOR_ALLOWLIST_ONLY=true
JUDGE_MODE_ENABLED=false
MERCHANT_MUTATIONS_ENABLED=true
REFUNDS_ENABLED=false
WITHDRAWALS_ENABLED=false
SPLITS_ENABLED=false
INDEXER_ENABLED=false
INDEXER_WRITES_ENABLED=false
INDEXER_RECONCILIATION_ENABLED=true

# Magic — placeholders only
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=pk_live_REPLACE_ME
MAGIC_SECRET_KEY=sk_live_REPLACE_ME
MAGIC_CLIENT_ID=REPLACE_WITH_EXPECTED_AUDIENCE

# Particle — verify which values are public/client-safe in current dashboard/docs
NEXT_PUBLIC_PARTICLE_PROJECT_ID=REPLACE_ME
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=REPLACE_ME
NEXT_PUBLIC_PARTICLE_APP_UUID=REPLACE_ME
PARTICLE_RPC_URL=

# Arbitrum / contracts
NEXT_PUBLIC_ARBITRUM_CHAIN_ID=42161
NEXT_PUBLIC_ARBITRUM_PUBLIC_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_RPC_URL=REPLACE_WITH_AUTHENTICATED_RPC
ARBITRUM_FALLBACK_RPC_URL=REPLACE_WITH_INDEPENDENT_RPC
NEXT_PUBLIC_USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
NEXT_PUBLIC_CHECKOUT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PASS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SPLIT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_EXPLORER_BASE_URL=https://arbiscan.io
CONFIRMATION_DEPTH=2
REORG_WINDOW_BLOCKS=512
INDEXER_DEPLOYMENT_BLOCK=0
INDEXER_MAX_BLOCK_RANGE=1000
INDEXER_LEASE_TTL_MS=30000
INDEXER_POLL_INTERVAL_MS=5000
INDEXER_RETRY_BASE_MS=1000
INDEXER_RETRY_MAX_MS=60000
INDEXER_RPC_FAILURE_THRESHOLD=3
INDEXER_RPC_COOLDOWN_MS=30000
INDEXER_RPC_TIMEOUT_MS=15000
INDEXER_HEALTH_PORT=3002
INDEXER_HEALTH_HOST=0.0.0.0
INDEXER_MAX_READY_LAG_BLOCKS=20
INDEXER_STALE_AFTER_MS=120000
INDEXER_MAX_CONSECUTIVE_FAILURES=5
INDEXER_STREAM=opentab-contracts-v3
INDEXER_LEASE_OWNER=

# Database / Redis
# Production Supabase mapping:
# - DATABASE_URL: opentab_runtime via Supavisor transaction mode, port 6543.
# - INDEXER/MIGRATIONS/EVIDENCE_WRITER: direct or Supavisor session mode, port 5432.
# Append sslmode=verify-full (preferred) or another validated TLS mode. Never put
# real URLs in this file. See docs/07-operations/SUPABASE_POSTGRES.md.
# Web/API runtime role only. The indexer must use DATABASE_URL_INDEXER.
DATABASE_URL=postgresql://opentab:opentab@localhost:5432/opentab
# Dedicated least-privilege indexer role; provision it before enabling the indexer.
DATABASE_URL_INDEXER=postgresql://opentab_indexer:REPLACE_WITH_32_PLUS_RANDOM_BYTES@localhost:5432/opentab
DATABASE_URL_MIGRATIONS=postgresql://opentab:opentab@localhost:5432/opentab
# Protected live-acceptance CLI only; use a distinct role and never expose it to web/indexer.
DATABASE_URL_EVIDENCE_WRITER=
# Vercel and Railway must share one authenticated rediss:// TCP endpoint.
# Upstash Redis is the documented default; its REST variables do not replace this URL.
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Session/security — generate random values; never use examples in production
SESSION_HASH_PEPPER=REPLACE_WITH_32_PLUS_RANDOM_BYTES
CSRF_SECRET=REPLACE_WITH_32_PLUS_RANDOM_BYTES
CAPABILITY_TOKEN_PEPPER=REPLACE_WITH_32_PLUS_RANDOM_BYTES
PRIVACY_SUBJECT_HASH_SECRET=REPLACE_WITH_32_PLUS_RANDOM_BYTES
JUDGE_SHARE_TOKEN_SECRET=REPLACE_WITH_32_PLUS_RANDOM_BYTES
LIVE_ACCEPTANCE_ATTESTATION_SECRET=REPLACE_WITH_32_PLUS_RANDOM_BYTES
# Non-Vercel live hosts: exact lowercase 40-hex deployed Git commit.
APPLICATION_RELEASE_ID=
LIVE_ACCEPTANCE_RELEASE_ID=REPLACE_WITH_EXACT_40_HEX_DEPLOYED_GIT_COMMIT
SESSION_MAX_AGE_SECONDS=604800
CHECKOUT_SESSION_TTL_SECONDS=900
PAYMENT_INTENT_TTL_SECONDS=900
PLATFORM_FEE_BPS=
PARTICLE_QUOTE_SAFETY_SECONDS=20
PARTICLE_MAX_SLIPPAGE_BPS=100
PARTICLE_MAX_FEE_USD_MICROS=5000000
PARTICLE_ALLOWED_SOURCE_CHAIN_IDS=1,8453,42161
PARTICLE_ALLOWED_SOURCE_ASSETS=USDC,USDT,ETH
# Required in live mode as chainId:SYMBOL:tokenAddress entries.
PARTICLE_ALLOWED_SOURCE_TOKENS=
# Exact reviewed non-Arbitrum user-operation bundles. Keep [] until a
# sanitized live fixture has been reviewed; live Particle mode fails closed.
PARTICLE_SOURCE_CALL_PROFILES_JSON=[]
PRODUCT_MEDIA_ALLOWED_ORIGINS=
PARTICLE_EIP7702_IMPLEMENTATION_ADDRESS=
PARTICLE_EIP7702_IMPLEMENTATION_CODE_HASH=
PARTICLE_RESPONSE_PROFILE_ID=
PARTICLE_RESPONSE_PROFILE_PROVENANCE=deterministic
PARTICLE_DEPLOYMENTS_FIXTURE_DIGEST=
PARTICLE_AUTH_FIXTURE_DIGEST=
PARTICLE_SUBMISSION_FIXTURE_DIGEST=
PARTICLE_STATUS_FIXTURE_DIGEST=
PARTICLE_MAGIC_AUTHORIZATION_NONCE_OFFSET=
PARTICLE_DELEGATION_PLAN_TTL_SECONDS=

# EIP-712 order/split signer — managed signer required in production
ORDER_SIGNER_MODE=disabled
ORDER_SIGNER_PRIVATE_KEY=
ORDER_SIGNER_KMS_KEY_ID=
ORDER_SIGNER_ADDRESS=
SPLIT_SIGNER_MODE=disabled
SPLIT_SIGNER_PRIVATE_KEY=
SPLIT_SIGNER_KEY_ID=
SPLIT_SIGNER_EXPECTED_ADDRESS=
SPLIT_REVOCATION_MAX_FEE_PER_GAS_WEI=5000000000
SPLIT_REVOCATION_MAX_GAS_LIMIT=200000
AWS_KMS_REGION=
VERCEL_AWS_ROLE_ARN=

# Bootstrap sponsor — use managed signer in production; private-key mode demo only
SPONSOR_SIGNER_MODE=disabled
SPONSOR_PRIVATE_KEY=
SPONSOR_KMS_KEY_ID=
SPONSOR_SIGNER_ADDRESS=
SPONSOR_MAX_FEE_PER_GAS_WEI=0
SPONSOR_MIN_GRANT_WEI=0
SPONSOR_TARGET_BALANCE_WEI=0
SPONSOR_PER_GRANT_CAP_WEI=0
SPONSOR_PER_ADDRESS_DAILY_CAP_WEI=0
SPONSOR_PER_USER_DAILY_CAP_WEI=0
SPONSOR_PER_IP_DAILY_CAP_WEI=0
SPONSOR_PER_DEVICE_DAILY_CAP_WEI=0
SPONSOR_GLOBAL_DAILY_CAP_WEI=0
SPONSOR_LOW_BALANCE_ALERT_WEI=0
SPONSOR_ALLOWED_ADDRESSES=

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional providers
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
EMAIL_PROVIDER_API_KEY=
ANALYTICS_WRITE_KEY=
